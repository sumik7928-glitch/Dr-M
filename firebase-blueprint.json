{
  "entities": {
    "User": {
      "title": "User",
      "description": "Patient profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientAge": { "type": "number" },
        "patientPhone": { "type": "string" },
        "symptoms": { "type": "string" },
        "city": { "type": "string", "enum": ["Hyderabad", "Mirpurkhas"] },
        "clinicLocation": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "timeSlot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "patientName", "patientPhone", "city", "clinicLocation", "date", "timeSlot", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    }
  }
}
